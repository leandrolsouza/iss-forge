{
  "name": "iss-forge",
  "version": "0.1.0-beta",
  "description": "ISS Forge - ROM Editor for International Superstar Soccer (SNES 1995)",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "node scripts/dev.js",
    "electron:start": "electron .",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"electron/**/*.js\" \"scripts/**/*.js\" \"vite.config.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\" \"electron/**/*.js\" \"scripts/**/*.js\" \"vite.config.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": {
    "name": "Leandro Luiz De Souza",
    "email": "leandrolsouza@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.iss-forge.app",
    "productName": "ISS Forge",
    "publish": [
      {
        "provider": "github",
        "owner": "leandrolsouza",
        "repo": "iss-forge"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}